#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/../.." && pwd)"
cd "$ROOT_DIR"

usage() {
  cat <<'EOF'
Usage: .pi/tools/dev <command> [args...]

Commands:
  up [services...]          Start docker services (docker compose up -d)
  db [psql args...]         Open psql using DB config from docker/odoo_*.conf
  shell [db_name]           Start Odoo shell (--no-http) in odoo container
  test [run-tests args...]  Run ./run-tests.sh with forwarded args
  lint [pre-commit args...] Run pre-commit (defaults to run --all-files)
  help                      Show this help

Examples:
  .pi/tools/dev up
  .pi/tools/dev db
  .pi/tools/dev db -c "SELECT COUNT(*) FROM res_partner;"
  .pi/tools/dev shell
  .pi/tools/dev shell postgres
  .pi/tools/dev test -u philoro_products
  .pi/tools/dev lint
EOF
}

load_pg_env() {
  eval "$(python3 - <<'PY'
import configparser
from pathlib import Path

cfg = configparser.ConfigParser()
base = Path('docker/odoo_base.conf')
local = Path('docker/odoo_local.conf')
paths = [str(p) for p in (base, local) if p.exists()]
cfg.read(paths)
opt = cfg['options'] if cfg.has_section('options') else {}

vals = {
    'PGHOST': opt.get('db_host', 'localhost'),
    'PGPORT': opt.get('db_port', '5432'),
    'PGDATABASE': opt.get('db_name', 'postgres'),
    'PGUSER': opt.get('db_user', 'odoo'),
    'PGPASSWORD': opt.get('db_password', 'odoo'),
}

if vals['PGHOST'] in ('postgres', 'db'):
    vals['PGHOST'] = 'localhost'

for k, v in vals.items():
    v = str(v).replace('"', '\\"')
    print(f'export {k}="{v}"')
PY
)"
}

cmd_up() {
  docker compose up -d "$@"
}

cmd_db() {
  load_pg_env
  if command -v psql >/dev/null 2>&1; then
    psql "$@"
  else
    echo "psql not found locally; using postgres container psql"
    docker compose exec postgres psql -U "$PGUSER" -d "$PGDATABASE" "$@"
  fi
}

cmd_shell() {
  load_pg_env
  local db_name="${1:-${DATABASE:-$PGDATABASE}}"
  docker compose exec odoo odoo shell --no-http -d "$db_name"
}

cmd_test() {
  ./run-tests.sh "$@"
}

cmd_lint() {
  if [ "$#" -eq 0 ]; then
    pre-commit run --all-files
  else
    pre-commit run "$@"
  fi
}

cmd="${1:-help}"
shift || true

case "$cmd" in
  up) cmd_up "$@" ;;
  db) cmd_db "$@" ;;
  shell) cmd_shell "$@" ;;
  test) cmd_test "$@" ;;
  lint) cmd_lint "$@" ;;
  help|-h|--help) usage ;;
  *)
    echo "Unknown command: $cmd" >&2
    echo
    usage
    exit 1
    ;;
esac
