# Odoo Skill Manager recommended environment (direnv + venv)
export ODOO_SKILL_MANAGER_ROOT="$(pwd)"
# Legacy compatibility variables
export ODOO_DEVKIT_ROOT="$ODOO_SKILL_MANAGER_ROOT"
export ERP_DEVKIT_ROOT="$ODOO_SKILL_MANAGER_ROOT"

if [ ! -d .venv ]; then
  python3 -m venv .venv
fi

source .venv/bin/activate
export PATH="$ODOO_SKILL_MANAGER_ROOT/commands:$PATH"
